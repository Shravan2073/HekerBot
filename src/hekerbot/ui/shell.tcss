Screen {
    layout: horizontal;
    background: $surface;
}

#sidebar {
    width: 30%;
    height: 100%;
    border-right: vkey $background;
}

#content-area {
    width: 70%;
    height: 100%;
    padding: 1 2;
}

OptionList {
    background: $surface;
    border: none;
}
OptionList:focus > .option-list--option-highlighted {
    background: $accent;
    color: $text;
}
